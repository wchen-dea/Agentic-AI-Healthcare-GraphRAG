# External managed services for production runtime
QDRANT_URL=https://qdrant.company.example
QDRANT_COLLECTION=healthcare_events
NEO4J_URI=neo4j+s://neo4j.company.example:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me

# LLM provider routing (recommended in production)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=120
LLM_MAX_TOKENS=1200
LLM_TEMPERATURE=0.2
OPENAI_API_KEY=change_me

# Optional local fallback settings
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1

# Embedded MCP settings in rag-api process
MCP_SERVER_NAME=HealthcareGraphRAG MCP
RAG_API_TOOL_POLICY_PATH=/app/config/tool_policies.json
RAG_API_DEFAULT_CALLER_ROLE=generation
RAG_API_ALLOW_ORIGINS=https://provider.company.example
RAG_API_AUDIT_LOG_PATH=/var/log/rag-api/audit.log
RAG_API_MAX_QUESTION_CHARS=1000
RAG_API_MAX_CONTEXT_ITEMS=5
RAG_API_MAX_EVIDENCE_CHARS=240
RAG_API_MAX_ANSWER_CHARS=2000
RAG_API_MAX_RESPONSE_BYTES=50000
